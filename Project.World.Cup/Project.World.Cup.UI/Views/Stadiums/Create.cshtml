@model Project.World.Cup.Model.Stadium

@{
    ViewData["Title"] = "Yeni Stadyum Ekle";
}

@section Styles {
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
}

<div class="container entity-page">
    <div class="entity-hero">
        <h1>Yeni Stadyum Ekle</h1>
        <p>
            Maçların oynanacağı stadyumları, şehirlerini, ülkelerini ve kapasite bilgilerini sisteme kaydedebilirsin.
        </p>
    </div>

    <div class="form-shell">
        <div class="form-card">
            <div class="form-card-header">
                <div>
                    <span class="form-kicker">Stadyum Yönetimi</span>
                    <h2>Stadyum Bilgileri</h2>
                    <p>Stadyum detaylarını girerek yeni kayıt oluştur.</p>
                </div>

                <div class="form-icon-box">
                    <span>🏟️</span>
                </div>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group-modern">
                    <label asp-for="StadiumName">Stadyum Adı</label>
                    <input asp-for="StadiumName" class="form-control modern-input" placeholder="Örn: Lusail Stadium" />
                    <span asp-validation-for="StadiumName" class="text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="City">Şehir</label>
                    <input asp-for="City" class="form-control modern-input" placeholder="Örn: Lusail" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="Country">Ülke</label>
                    <input asp-for="Country" class="form-control modern-input" placeholder="Örn: Qatar" />
                    <span asp-validation-for="Country" class="text-danger"></span>
                </div>

                <div class="form-group-modern">
                    <label asp-for="Capacity">Kapasite</label>
                    <input asp-for="Capacity" class="form-control modern-input" type="number" placeholder="Örn: 88966" />
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>

                <div class="form-actions-modern">
                    <a asp-action="Index" class="btn-back-modern">Listeye Dön</a>
                    <button type="submit" class="btn-save-modern">Stadyumu Kaydet</button>
                </div>
            </form>
        </div>

        <div class="form-info-card">
            <h3>Bilgilendirme</h3>
            <p>
                Stadyumlar, maç kayıtlarına bağlanarak turnuva takviminin hangi arenalarda gerçekleşeceğini belirler.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/script.js" asp-append-version="true"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
