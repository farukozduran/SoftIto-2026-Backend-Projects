@model Project.World.Cup.Model.Stadium

@{
    ViewData["Title"] = "Stadyum Sil";
}

@section Styles {
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
}

<div class="container entity-page">
    <div class="entity-hero danger-hero">
        <h1>Stadyum Sil</h1>
        <p>
            Seçili stadyum kaydını silmek üzeresin. Bu işlemden önce stadyumun bağlı olduğu maç kayıtlarını kontrol etmelisin.
        </p>
    </div>

    <div class="delete-shell">
        <div class="delete-card">
            <div class="delete-icon">!</div>
            <div class="delete-content">
                <span class="form-kicker danger-text">Silme Onayı</span>
                <h2>@Model.StadiumName silinsin mi?</h2>
                <p>
                    Bu işlem geri alınamaz. Eğer bu stadyuma atanmış maç kayıtları varsa,
                    veritabanı ilişkilerinden dolayı silme işlemi hata verebilir.
                </p>

                <div class="delete-details">
                    <div class="delete-detail-item">
                        <small>Stadyum Adı</small>
                        <span>@Model.StadiumName</span>
                    </div>

                    <div class="delete-detail-item">
                        <small>Şehir / Ülke</small>
                        <span>@Model.City / @(string.IsNullOrEmpty(Model.Country) ? "Belirtilmedi" : Model.Country)</span>
                    </div>

                    <div class="delete-detail-item">
                        <small>Kapasite</small>
                        <span>@(Model.Capacity.HasValue ? Model.Capacity.Value.ToString("N0") : "Belirtilmedi")</span>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="StadiumId" />

                    <div class="form-actions-modern">
                        <a asp-action="Index" class="btn-back-modern">Vazgeç</a>
                        <button type="submit" class="btn-delete-modern">Evet, Stadyumu Sil</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/script.js" asp-append-version="true"></script>
}
