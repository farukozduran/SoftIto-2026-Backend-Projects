@page "{id:int}"
@model CafeManagementAdoNet.Pages.Expenses.DeleteModel

@{
    ViewData["Title"] = "Gider Sil";
}

<div class="cafe-page">
    <div class="cafe-container">

        <section class="cafe-hero">
            <div>
                <div class="cafe-kicker">Silme İşlemi</div>
                <h1>Gider Sil</h1>
                <p>Bu işlem seçili gider kaydını veritabanından kaldırır.</p>
            </div>

            <div class="cafe-hero-actions">
                <a asp-page="Index" class="cafe-btn cafe-btn-soft">Giderlere Dön</a>
            </div>
        </section>

        <section class="cafe-card">
            <div class="cafe-card-body">
                <div class="cafe-delete-panel">
                    <h3>Bu gider kaydını silmek istediğine emin misin?</h3>
                    <p class="cafe-muted mb-0">Silme işleminden sonra bu gider kaydı listede görünmez.</p>
                </div>

                <dl class="cafe-detail-list">
                    <div class="cafe-detail-row">
                        <dt>Gider Başlığı</dt>
                        <dd>@Model.Expense.ExpenseTitle</dd>
                    </div>

                    <div class="cafe-detail-row">
                        <dt>Tutar</dt>
                        <dd>@Model.Expense.Amount.ToString("N2") ₺</dd>
                    </div>

                    <div class="cafe-detail-row">
                        <dt>Gider Tarihi</dt>
                        <dd>@Model.Expense.ExpenseDate.ToString("dd.MM.yyyy")</dd>
                    </div>

                    <div class="cafe-detail-row">
                        <dt>Açıklama</dt>
                        <dd>@(string.IsNullOrWhiteSpace(Model.Expense.Description) ? "-" : Model.Expense.Description)</dd>
                    </div>
                </dl>

                <form method="post">
                    <input type="hidden" asp-for="Expense.ExpenseId" />

                    <div class="cafe-form-actions">
                        <a asp-page="Index" class="cafe-btn cafe-btn-outline">Vazgeç</a>
                        <button type="submit" class="cafe-btn cafe-btn-danger">Sil</button>
                    </div>
                </form>
            </div>
        </section>

    </div>
</div>