@page
@model CafeManagementAdoNet.Pages.Expenses.IndexModel

@{
    ViewData["Title"] = "Giderler";

    var totalExpense = Model.Expenses.Count;
    var totalAmount = Model.Expenses.Sum(x => x.Amount);
    var averageAmount = Model.Expenses.Any() ? Model.Expenses.Average(x => x.Amount) : 0;
}

<div class="cafe-page">
    <div class="cafe-container">

        <section class="cafe-hero">
            <div>
                <div class="cafe-kicker">Kafe Yönetimi</div>
                <h1>Giderler</h1>
                <p>Kafeye ait gider kayıtlarını, tutarları ve açıklamaları buradan takip edebilirsin.</p>
            </div>

            <div class="cafe-hero-actions">
                <a asp-page="Create" class="cafe-btn cafe-btn-primary">+ Yeni Gider</a>
            </div>
        </section>
        <section class="cafe-search-panel">
            <form method="get" class="cafe-search-form">
                <div class="cafe-search-box">
                    <span class="cafe-search-icon">⌕</span>
                    <input asp-for="SearchTerm"
                           class="cafe-search-input"
                           placeholder="Gider başlığı veya açıklama ara..." />
                </div>

                <button type="submit" class="cafe-btn cafe-btn-primary">
                    Ara
                </button>

                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <a asp-page="./Index" class="cafe-btn cafe-btn-outline">
                        Temizle
                    </a>
                }
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <div class="cafe-search-result-text">
                    “@Model.SearchTerm” araması için @Model.Expenses.Count sonuç bulundu.
                </div>
            }
        </section>

        <section class="cafe-stats">
            <div class="cafe-stat-card">
                <div class="cafe-stat-label">Toplam Gider Kaydı</div>
                <div class="cafe-stat-value">@totalExpense</div>
            </div>

            <div class="cafe-stat-card">
                <div class="cafe-stat-label">Toplam Tutar</div>
                <div class="cafe-stat-value">@totalAmount.ToString("N2") ₺</div>
            </div>

            <div class="cafe-stat-card">
                <div class="cafe-stat-label">Ortalama Gider</div>
                <div class="cafe-stat-value">@averageAmount.ToString("N2") ₺</div>
            </div>
        </section>

        <section class="cafe-card">
            <div class="cafe-card-header">
                <div>
                    <h2 class="cafe-card-title">Gider Listesi</h2>
                    <p class="cafe-card-subtitle">Kayıtlı giderleri görüntüle, düzenle veya sil.</p>
                </div>
            </div>

            <div class="cafe-card-body">
                @if (Model.Expenses.Any())
                {
                    <div class="cafe-table-wrap">
                        <table class="cafe-table">
                            <thead>
                                <tr>
                                    <th>Gider</th>
                                    <th>Tutar</th>
                                    <th>Tarih</th>
                                    <th>Açıklama</th>
                                    <th class="text-end">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Expenses)
                                {
                                    <tr>
                                        <td class="cafe-title-cell">@item.ExpenseTitle</td>
                                        <td class="cafe-price">@item.Amount.ToString("N2") ₺</td>
                                        <td>@item.ExpenseDate.ToString("dd.MM.yyyy")</td>
                                        <td class="cafe-muted">@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</td>
                                        <td>
                                            <div class="cafe-actions">
                                                <a asp-page="Edit" asp-route-id="@item.ExpenseId" class="cafe-btn cafe-btn-sm cafe-btn-warning">Düzenle</a>
                                                <a asp-page="Delete" asp-route-id="@item.ExpenseId" class="cafe-btn cafe-btn-sm cafe-btn-danger">Sil</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="cafe-empty">
                        Henüz gider kaydı bulunmuyor.
                    </div>
                }
            </div>
        </section>

    </div>
</div>