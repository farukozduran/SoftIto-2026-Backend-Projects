@page
@model CafeManagementAdoNet.Pages.Employees.CreateModel

@{
    ViewData["Title"] = "Yeni Çalışan";
}

<div class="cafe-page">
    <div class="cafe-container">

        <section class="cafe-hero">
            <div>
                <div class="cafe-kicker">Çalışan İşlemleri</div>
                <h1>Yeni Çalışan Ekle</h1>
                <p>Kafe personeli için yeni bir kayıt oluştur.</p>
            </div>

            <div class="cafe-hero-actions">
                <a asp-page="Index" class="cafe-btn cafe-btn-soft">Çalışanlara Dön</a>
            </div>
        </section>

        <section class="cafe-card">
            <div class="cafe-card-header">
                <div>
                    <h2 class="cafe-card-title">Çalışan Bilgileri</h2>
                    <p class="cafe-card-subtitle">Ad soyad, pozisyon, maaş ve işe başlangıç tarihini gir.</p>
                </div>
            </div>

            <div class="cafe-card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="cafe-form-grid">
                        <div class="cafe-form-group">
                            <label asp-for="Employee.FullName" class="cafe-label">Ad Soyad</label>
                            <input asp-for="Employee.FullName" class="cafe-input" placeholder="Örn: Ali Yılmaz" />
                            <span asp-validation-for="Employee.FullName" class="text-danger cafe-validation"></span>
                        </div>

                        <div class="cafe-form-group">
                            <label asp-for="Employee.Position" class="cafe-label">Pozisyon</label>
                            <input asp-for="Employee.Position" class="cafe-input" placeholder="Örn: Barista" />
                            <span asp-validation-for="Employee.Position" class="text-danger cafe-validation"></span>
                        </div>

                        <div class="cafe-form-group">
                            <label asp-for="Employee.Salary" class="cafe-label">Maaş</label>
                            <input asp-for="Employee.Salary" class="cafe-input" placeholder="Örn: 25000" />
                            <span asp-validation-for="Employee.Salary" class="text-danger cafe-validation"></span>
                        </div>

                        <div class="cafe-form-group">
                            <label asp-for="Employee.StartDate" class="cafe-label">Başlangıç Tarihi</label>
                            <input asp-for="Employee.StartDate" type="date" class="cafe-input" />
                            <span asp-validation-for="Employee.StartDate" class="text-danger cafe-validation"></span>
                        </div>
                    </div>

                    <div class="cafe-form-actions">
                        <a asp-page="Index" class="cafe-btn cafe-btn-outline">Vazgeç</a>
                        <button type="submit" class="cafe-btn cafe-btn-success">Kaydet</button>
                    </div>
                </form>
            </div>
        </section>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}