@using Project.Shop.Models

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var summary = ViewBag.DashboardSummary as DashboardSummaryReport;
    var topSellingProducts = ViewBag.TopSellingProducts as List<TopSellingProductReport>;
    var topCustomers = ViewBag.TopCustomers as List<TopCustomerReport>;
    var categorySales = ViewBag.CategorySales as List<CategorySalesReport>;
    var latestOrders = ViewBag.LatestOrders as List<Order>;
}

<h1 class="h3 mb-4 text-gray-800">Admin Dashboard</h1>

@if (summary != null)
{
    <div class="row">
        <!-- Total Orders -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Orders</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@summary.TotalOrders</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-shopping-cart fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Revenue -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Revenue</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@summary.TotalRevenue.ToString("C")</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Customers -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Total Customers</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@summary.TotalCustomers</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Products -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Total Products</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@summary.TotalProducts</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-box fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row">
    <!-- Top Selling Products -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Top Selling Products</h6>
            </div>
            <div class="card-body">
                @if (topSellingProducts != null && topSellingProducts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered" width="100%" cellspacing="0">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Category</th>
                                    <th>Sales</th>
                                    <th>Revenue</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in topSellingProducts)
                                {
                                    <tr>
                                        <td>@item.ProductName</td>
                                        <td>@item.CategoryName</td>
                                        <td>@item.SalesCount</td>
                                        <td>@item.TotalRevenue.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p>No product sales data available.</p>
                }
            </div>
        </div>
    </div>

    <!-- Top Customers -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-success">Top Spending Customers</h6>
            </div>
            <div class="card-body">
                @if (topCustomers != null && topCustomers.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered" width="100%" cellspacing="0">
                            <thead>
                                <tr>
                                    <th>Customer</th>
                                    <th>Orders</th>
                                    <th>Total Spent</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in topCustomers)
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <img src="@item.ImageUrl" alt="@item.CustomerName" class="img-profile rounded-circle mr-2" style="width: 30px; height: 30px; object-fit: cover;" />
                                            }
                                            @item.CustomerName
                                        </td>
                                        <td>@item.OrderCount</td>
                                        <td>@item.TotalSpent.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p>No customer data available.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Category Sales -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-info">Sales by Category</h6>
            </div>
            <div class="card-body">
                @if (categorySales != null && categorySales.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var item in categorySales)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="font-weight-bold">@item.CategoryName</span>
                                    <br />
                                    <small class="text-muted">@item.SalesCount sales</small>
                                </div>
                                <span class="badge badge-info badge-pill">@item.TotalRevenue.ToString("C")</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p>No category sales data available.</p>
                }
            </div>
        </div>
    </div>

    <!-- Latest Orders -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-warning">Latest Orders</h6>
            </div>
            <div class="card-body">
                @if (latestOrders != null && latestOrders.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered" width="100%" cellspacing="0">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Product</th>
                                    <th>Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in latestOrders)
                                {
                                    <tr>
                                        <td>#@item.OrderId</td>
                                        <td>@item.Customer?.CustomerName</td>
                                        <td>@item.Product?.ProductName</td>
                                        <td>@item.Product?.Price.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p>No recent orders available.</p>
                }
            </div>
        </div>
    </div>
</div>

<hr />

<h2 class="h4 mb-4 text-gray-800">Quick Actions</h2>
<div class="row">
    <!-- Category Management -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-secondary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">Categories</div>
                    </div>
                    <div class="col-auto"><i class="fas fa-list fa-2x text-gray-300"></i></div>
                </div>
                <div class="mt-3">
                    <a asp-controller="Categories" asp-action="Index" asp-route-isAdmin="true" class="btn btn-secondary btn-sm">Manage Categories</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Management -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-secondary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">Products</div>
                    </div>
                    <div class="col-auto"><i class="fas fa-box fa-2x text-gray-300"></i></div>
                </div>
                <div class="mt-3">
                    <a asp-controller="Products" asp-action="Index" asp-route-isAdmin="true" class="btn btn-secondary btn-sm">Manage Products</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Customer Management -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-secondary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">Customers</div>
                    </div>
                    <div class="col-auto"><i class="fas fa-users fa-2x text-gray-300"></i></div>
                </div>
                <div class="mt-3">
                    <a asp-controller="Customers" asp-action="Index" asp-route-isAdmin="true" class="btn btn-secondary btn-sm">Manage Customers</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Management -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-secondary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">Orders</div>
                    </div>
                    <div class="col-auto"><i class="fas fa-receipt fa-2x text-gray-300"></i></div>
                </div>
                <div class="mt-3">
                    <a asp-controller="Orders" asp-action="Index" asp-route-isAdmin="true" class="btn btn-secondary btn-sm">Manage Orders</a>
                </div>
            </div>
        </div>
    </div>
</div>