@model HotelReservationSystem.Entity.Entities.Hotel

<div class="container mt-4">
    <h2>@(Model.Id != 0 ? "Otel Düzenle" : "Yeni Otel Ekle")</h2>
    <hr />

    <form asp-action="Crup" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Photo" />

        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Otel Adı</label>
                    <input asp-for="Name" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="City" class="form-label">Şehir</label>
                    <input asp-for="City" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Adres</label>
                    <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="StarRating" class="form-label">Yıldız</label>
                    <input asp-for="StarRating" type="number" min="1" max="5" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Otel Görseli</label>
                    <input type="file" name="file" class="form-control" accept="image/*" />
                    @if (!string.IsNullOrEmpty(Model.Photo))
                    {
                        <div class="mt-2"><img src="@Model.Photo" style="height: 100px;" class="img-thumbnail" /></div>
                    }
                </div>
                <button type="submit" class="btn btn-success">Kaydet</button>
                <a asp-action="Index" class="btn btn-secondary">İptal</a>
            </div>
        </div>
    </form>
</div>