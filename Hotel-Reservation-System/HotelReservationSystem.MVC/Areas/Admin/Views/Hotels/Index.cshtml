@model IEnumerable<HotelReservationSystem.Entity.Entities.Hotel>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Oteller</h2>
        <a asp-action="Crup" asp-controller="Hotels" asp-area="Admin" class="btn btn-primary">Yeni Otel Ekle</a>
    </div>

    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Görsel</th>
                <th>Otel Adı</th>
                <th>Şehir</th>
                <th>Yıldız</th>
                <th class="text-center">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center align-middle">
                            @if (!string.IsNullOrEmpty(item.Photo))
                            {
                                <img src="@item.Photo" alt="Otel" style="width:80px; border-radius:5px;" />
                            }
                        </td>
                        <td class="align-middle">@item.Name</td>
                        <td class="align-middle">@item.City</td>
                        <td class="align-middle">@item.StarRating ⭐</td>
                        <td class="text-center align-middle">
                            <a asp-action="Crup" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Emin misiniz?');">Sil</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>