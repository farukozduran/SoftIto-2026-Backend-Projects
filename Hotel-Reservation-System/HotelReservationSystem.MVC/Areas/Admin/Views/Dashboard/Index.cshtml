@model HotelReservationSystem.MVC.Areas.Admin.Models.DashboardReportViewModel

<div class="row mt-5">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0">Detaylı Rezervasyon Raporu</h5>
            </div>
            <div class="card-body">
                <table id="reservationReportTable" class="table table-striped table-bordered w-100">
                    <thead>
                        <tr>
                            <th>Rez. No</th>
                            <th>Misafir Adı</th>
                            <th>Otel Adı</th>
                            <th>Oda Tipi</th>
                            <th>Oda No</th>
                            <th>Giriş Tarihi</th>
                            <th>Çıkış Tarihi</th>
                            <th>Toplam Tutar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ReservationReports)
                        {
                            <tr>
                                <td>@item.ReservationId</td>
                                <td>@item.GuestFullName</td>
                                <td>@item.HotelName</td>
                                <td>@item.RoomTypeName</td>
                                <td>@item.RoomNumber</td>
                                <td>@item.CheckInDate.ToShortDateString()</td>
                                <td>@item.CheckOutDate.ToShortDateString()</td>
                                <td>@item.TotalAmount.ToString("C2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css" />

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>

    <script>
        $(document).ready(function() {
        $('#reservationReportTable').DataTable({
        dom: 'Bfrtip',
        buttons: [
        {
        extend: 'excelHtml5',
        text: '<i class="bi bi-file-earmark-excel"></i> Excel Olarak İndir',
        className: 'btn btn-success btn-sm mb-3 ms-2'
        },
        {
        extend: 'pdfHtml5',
        text: '<i class="bi bi-file-earmark-pdf"></i> PDF Olarak İndir',
        className: 'btn btn-danger btn-sm mb-3 ms-2',
        orientation: 'landscape', 
        pageSize: 'A4'
        }
        ],
        language: {
        url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json'
        }
        });
        });
    </script>
}