@model IEnumerable<HotelReservationSystem.Entity.Entities.Room>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Odalar</h2>
        <a asp-action="Crup" asp-controller="Rooms" asp-area="Admin" class="btn btn-primary">Yeni Oda Ekle</a>
    </div>

    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Oda Numarası</th>
                <th>Gecelik Fiyat</th>
                <th class="text-center">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle">@item.RoomNumber</td>
                        <td class="align-middle">@item.NightlyPrice.ToString("C2")</td>
                        <td class="text-center align-middle">
                            <a asp-action="Crup" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bu odayı silmek istediğinize emin misiniz?');">Sil</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center">Henüz oda eklenmemiş.</td>
                </tr>
            }
        </tbody>
    </table>
</div>