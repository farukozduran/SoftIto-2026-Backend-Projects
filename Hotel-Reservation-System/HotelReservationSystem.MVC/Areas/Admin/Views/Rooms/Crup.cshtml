@model HotelReservationSystem.MVC.Models.ViewModels.RoomViewModel

<div class="container mt-4">
    <h2>@(Model.Room.Id != 0 ? "Oda Düzenle" : "Yeni Oda Ekle")</h2>
    <hr />

    <form asp-action="Crup" method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="Room.Id" />

        <input type="hidden" asp-for="Room.Photo" />

        <div class="row">
            <div class="col-md-6">

                <div class="mb-3">
                    <label asp-for="Room.RoomNumber" class="form-label">Oda Numarası</label>
                    <input asp-for="Room.RoomNumber" class="form-control" placeholder="Örn: 101, A-1" />
                    <span asp-validation-for="Room.RoomNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Room.NightlyPrice" class="form-label">Gecelik Fiyat</label>
                    <input asp-for="Room.NightlyPrice" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Room.NightlyPrice" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Room.HotelId" class="form-label">Otel Seçiniz</label>
                    <select asp-for="Room.HotelId" asp-items="Model.HotelList" class="form-select">
                        <option disabled selected value="">-- Otel Seçin --</option>
                    </select>
                    <span asp-validation-for="Room.HotelId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Room.RoomTypeId" class="form-label">Oda Tipi Seçiniz</label>
                    <select asp-for="Room.RoomTypeId" asp-items="Model.RoomTypeList" class="form-select">
                        <option disabled selected value="">-- Oda Tipi Seçin --</option>
                    </select>
                    <span asp-validation-for="Room.RoomTypeId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Oda Görseli Yükle</label>
                    <input type="file" name="file" class="form-control" accept="image/*" />

                    @if (!string.IsNullOrEmpty(Model.Room.Photo))
                    {
                        <div class="mt-3 p-2 border rounded">
                            <p class="mb-1 text-muted">Mevcut Görsel:</p>
                            <img src="@Model.Room.Photo" alt="Mevcut Oda Görseli" style="max-height: 150px; width: auto;" class="img-thumbnail" />
                        </div>
                    }
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Kaydet
                    </button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">İptal / Geri Dön</a>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}