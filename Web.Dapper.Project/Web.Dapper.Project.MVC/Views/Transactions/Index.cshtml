@model IEnumerable<Transaction>
@{
    ViewData["Title"] = "Transactions";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-slate-900">Transactions</h1>
        <p class="text-sm text-slate-500">View and manage financial transactions.</p>
    </div>
    <a asp-action="Create" class="px-4 py-2 bg-blue-600 rounded-lg text-sm font-medium text-white hover:bg-blue-700 shadow-lg shadow-blue-500/20 transition-all">+ New Transaction</a>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
    <div class="flex-1 overflow-auto">
        <table class="w-full text-left whitespace-nowrap">
            <thead class="bg-slate-50 text-[10px] uppercase text-slate-400 font-bold border-b border-slate-200">
                <tr>
                    <th class="px-6 py-4">Date</th>
                    <th class="px-6 py-4">Account ID</th>
                    <th class="px-6 py-4">Type</th>
                    <th class="px-6 py-4 text-right">Amount</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @foreach (var item in Model) {
                    <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 text-slate-500 text-xs">@item.TransactionDate.ToString("MMM dd, yyyy HH:mm")</td>
                        <td class="px-6 py-4 font-mono text-xs text-slate-600">@item.AccountId</td>
                        <td class="px-6 py-4">
                            @if(item.TransactionType == "Deposit") {
                                <span class="px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 text-[10px] font-bold uppercase">Deposit</span>
                            } else if(item.TransactionType == "Withdrawal") {
                                <span class="px-2 py-0.5 rounded-full bg-red-100 text-red-700 text-[10px] font-bold uppercase">Withdraw</span>
                            } else {
                                <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 text-[10px] font-bold uppercase">Transfer</span>
                            }
                        </td>
                        <td class="px-6 py-4 text-right font-medium @(item.TransactionType == "Deposit" ? "text-emerald-600" : (item.TransactionType == "Withdrawal" ? "text-red-600" : "text-blue-600"))">
                            @(item.TransactionType == "Deposit" ? "+" : (item.TransactionType == "Withdrawal" ? "-" : ""))@item.Amount.ToString("N2")
                        </td>
                        <td class="px-6 py-4 text-right space-x-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="text-blue-600 hover:text-blue-800 text-sm font-medium">Edit</a>
                            <span class="text-slate-300">|</span>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="text-red-600 hover:text-red-800 text-sm font-medium">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>\n