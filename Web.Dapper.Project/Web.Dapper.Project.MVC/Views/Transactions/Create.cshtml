@model Transaction
@{
    ViewData["Title"] = "New Transaction";
}

<div class="mb-6">
    <a asp-action="Index" class="text-sm font-medium text-slate-500 hover:text-slate-800 flex items-center gap-1 mb-2"><i class="bi bi-arrow-left"></i> Back to List</a>
    <h1 class="text-2xl font-bold text-slate-900">Process New Transaction</h1>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 max-w-3xl">
    <form asp-action="Create" method="post">
        <div class="grid grid-cols-2 gap-6">
            <div>
                <label asp-for="AccountId" class="block text-sm font-semibold text-slate-700 mb-1">Select Account</label>
                <select asp-for="AccountId" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" asp-items="ViewBag.Accounts">
                    <option value="">-- Choose an Account --</option>
                </select>
                <span asp-validation-for="AccountId" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="TransactionType" class="block text-sm font-semibold text-slate-700 mb-1">Transaction Type</label>
                <select asp-for="TransactionType" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all">
                    <option value="Deposit">Deposit</option>
                    <option value="Withdrawal">Withdrawal</option>
                    <option value="Transfer">Transfer</option>
                </select>
                <span asp-validation-for="TransactionType" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Amount" class="block text-sm font-semibold text-slate-700 mb-1">Amount</label>
                <div class="flex">
                    <span class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-slate-200 bg-slate-100 text-slate-500 sm:text-sm font-bold">$</span>
                    <input asp-for="Amount" type="number" step="0.01" class="flex-1 w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-r-lg text-lg font-bold text-slate-900 focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all text-right" placeholder="0.00" />
                </div>
                <span asp-validation-for="Amount" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="TransactionDate" class="block text-sm font-semibold text-slate-700 mb-1">Date & Time</label>
                <input asp-for="TransactionDate" type="datetime-local" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="TransactionDate" class="text-red-500 text-xs mt-1 block"></span>
            </div>
        </div>
        <div class="mt-8 pt-6 border-t border-slate-100">
            <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 shadow-lg shadow-blue-500/20 transition-all">Process Transaction</button>
        </div>
    </form>
</div>\n