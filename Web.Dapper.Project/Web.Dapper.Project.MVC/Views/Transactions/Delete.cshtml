@model Transaction
@{
    ViewData["Title"] = "Delete Transaction";
}

<div class="mb-6">
    <a asp-action="Index" class="text-sm font-medium text-slate-500 hover:text-slate-800 flex items-center gap-1 mb-2"><i class="bi bi-arrow-left"></i> Back to List</a>
    <h1 class="text-2xl font-bold text-red-600">Delete Transaction</h1>
</div>

<div class="bg-red-50/50 rounded-2xl border border-red-100 shadow-sm p-6 max-w-2xl">
    <div class="flex items-start gap-4 mb-6">
        <div class="w-10 h-10 rounded-full bg-red-100 text-red-600 flex items-center justify-center shrink-0">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <div>
            <h3 class="text-lg font-bold text-red-800">Are you sure you want to void this transaction?</h3>
            <p class="text-sm text-red-600/80 mt-1">This action cannot be undone.</p>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-red-100 p-5 mb-6">
        <dl class="grid grid-cols-3 gap-y-4 text-sm">
            <dt class="text-slate-500 font-medium">Date</dt>
            <dd class="col-span-2 text-slate-700">@Model.TransactionDate.ToString("g")</dd>

            <dt class="text-slate-500 font-medium">Account ID</dt>
            <dd class="col-span-2 font-mono text-slate-700">@Model.AccountId</dd>

            <dt class="text-slate-500 font-medium">Type</dt>
            <dd class="col-span-2 text-slate-700">@Model.TransactionType</dd>

            <dt class="text-slate-500 font-medium">Amount</dt>
            <dd class="col-span-2 font-bold text-slate-900">@Model.Amount.ToString("N2")</dd>
        </dl>
    </div>

    <form asp-action="Delete" method="post" class="flex gap-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="px-6 py-2 bg-red-600 text-white rounded-lg text-sm font-semibold hover:bg-red-700 shadow-sm transition-all">Void Transaction</button>
        <a asp-action="Index" class="px-6 py-2 bg-white border border-slate-200 text-slate-700 rounded-lg text-sm font-semibold hover:bg-slate-50 shadow-sm transition-all">Cancel</a>
    </form>
</div>\n