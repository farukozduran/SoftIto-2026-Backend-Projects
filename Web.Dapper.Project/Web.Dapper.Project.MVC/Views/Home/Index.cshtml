@model Web.Dapper.Project.MVC.Models.HomeReportViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-slate-900">Dashboard Overview</h1>
        <p class="text-sm text-slate-500">Central monitoring for all bank operations and system health.</p>
    </div>
    <div class="flex gap-3">
        <a asp-controller="Transactions" asp-action="Create" class="px-4 py-2 bg-blue-600 rounded-lg text-sm font-medium text-white hover:bg-blue-700 shadow-lg shadow-blue-500/20 transition-all">+ Create Transaction</a>
    </div>
</div>

<!-- Main Grid Sections (Report Tables) -->
<div class="grid grid-cols-2 gap-6 mt-6">
    
    <!-- Table 1: Last 3 Transactions -->
    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
        <h4 class="font-bold text-sm mb-4">Son 3 İşlem</h4>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead>
                    <tr class="border-b border-slate-200">
                        <th class="pb-2 font-semibold">Tarih</th>
                        <th class="pb-2 font-semibold">İşlem Tipi</th>
                        <th class="pb-2 font-semibold text-right">Tutar</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach(var item in Model.Last3Transactions)
                    {
                        <tr>
                            <td class="py-2 text-slate-500">@item.TransactionDate.ToShortDateString()</td>
                            <td class="py-2">@item.TransactionType</td>
                            <td class="py-2 text-right font-medium">@item.Amount.ToString("C")</td>
                        </tr>
                    }
                    @if(!Model.Last3Transactions.Any())
                    {
                        <tr><td colspan="3" class="py-2 text-center text-slate-400">Kayıt bulunamadı.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Table 2: Customers containing 'A' -->
    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
        <h4 class="font-bold text-sm mb-4">İsminde 'A' Geçen Müşteriler</h4>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead>
                    <tr class="border-b border-slate-200">
                        <th class="pb-2 font-semibold">Ad Soyad</th>
                        <th class="pb-2 font-semibold">Email</th>
                        <th class="pb-2 font-semibold text-right">TCKN</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach(var item in Model.CustomersWithLetterA)
                    {
                        <tr>
                            <td class="py-2 font-medium">@item.FirstName @item.LastName</td>
                            <td class="py-2 text-slate-500">@item.Email</td>
                            <td class="py-2 text-right text-slate-500">@item.IdentityNumber</td>
                        </tr>
                    }
                    @if(!Model.CustomersWithLetterA.Any())
                    {
                        <tr><td colspan="3" class="py-2 text-center text-slate-400">Kayıt bulunamadı.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Table 3: Top Accounts -->
    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
        <h4 class="font-bold text-sm mb-4">En Yüksek Bakiyeli 5 Hesap</h4>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead>
                    <tr class="border-b border-slate-200">
                        <th class="pb-2 font-semibold">Hesap No</th>
                        <th class="pb-2 font-semibold">Para Birimi</th>
                        <th class="pb-2 font-semibold text-right">Bakiye</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach(var item in Model.TopAccounts)
                    {
                        <tr>
                            <td class="py-2 font-medium">@item.AccountNumber</td>
                            <td class="py-2 text-slate-500">@item.Currency</td>
                            <td class="py-2 text-right font-medium text-emerald-600">@item.Balance.ToString("C")</td>
                        </tr>
                    }
                    @if(!Model.TopAccounts.Any())
                    {
                        <tr><td colspan="3" class="py-2 text-center text-slate-400">Kayıt bulunamadı.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Table 4: Last 3 Branches -->
    <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
        <h4 class="font-bold text-sm mb-4">Son Eklenen Şubeler</h4>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead>
                    <tr class="border-b border-slate-200">
                        <th class="pb-2 font-semibold">ID</th>
                        <th class="pb-2 font-semibold">Şube Adı</th>
                        <th class="pb-2 font-semibold text-right">Şehir</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach(var item in Model.Last3Branches)
                    {
                        <tr>
                            <td class="py-2 text-slate-500">#@item.Id</td>
                            <td class="py-2 font-medium">@item.BranchName</td>
                            <td class="py-2 text-right text-slate-500">@item.City</td>
                        </tr>
                    }
                    @if(!Model.Last3Branches.Any())
                    {
                        <tr><td colspan="3" class="py-2 text-center text-slate-400">Kayıt bulunamadı.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>