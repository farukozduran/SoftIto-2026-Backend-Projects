@{
    Layout = "_Layout";
    ViewData["HideNavigation"] = true;
    ViewData["Title"] = "Login";
}
@model LoginViewModel

<div class="min-h-screen flex items-center justify-center bg-slate-50">
    <div class="bg-white p-8 rounded-2xl border border-slate-200 shadow-sm w-full max-w-md">
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-blue-600/10 text-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-4 text-3xl">
                <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center text-white font-bold text-lg">V</div>
            </div>
            <h3 class="text-2xl font-bold text-slate-900">Welcome Back</h3>
            <p class="text-sm text-slate-500">Sign in to VanguardBank Portal</p>
        </div>
        <form asp-action="Login" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
            <div>
                <label asp-for="IdentityNumber" class="block text-sm font-semibold text-slate-700 mb-1">Identity Number</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                        <i class="bi bi-person"></i>
                    </div>
                    <input asp-for="IdentityNumber" class="w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" placeholder="Enter 11-digit ID" maxlength="11" />
                </div>
                <span asp-validation-for="IdentityNumber" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Password" class="block text-sm font-semibold text-slate-700 mb-1">Password</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                        <i class="bi bi-lock"></i>
                    </div>
                    <input asp-for="Password" type="password" class="w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" placeholder="Enter password" />
                </div>
                <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <button type="submit" class="w-full py-2.5 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 shadow-lg shadow-blue-500/20 transition-all">Sign In</button>
        </form>
    </div>
</div>\n