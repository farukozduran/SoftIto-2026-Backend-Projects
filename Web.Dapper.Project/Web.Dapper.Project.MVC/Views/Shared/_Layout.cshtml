<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VanguardBank</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="h-full flex overflow-hidden bg-slate-50 text-slate-900">
    @if (!ViewData.ContainsKey("HideNavigation"))
    {
        <aside class="w-64 bg-slate-900 flex flex-col shrink-0">
            <div class="p-6 flex items-center gap-3">
                <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center text-white font-bold">V</div>
                <span class="text-white font-semibold text-xl tracking-tight">VanguardBank</span>
            </div>
            <nav class="flex-1 px-4 space-y-1">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </a>
                <a asp-controller="Customers" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                    <i class="bi bi-people"></i> Customers
                </a>
                <a asp-controller="Branches" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                    <i class="bi bi-building"></i> Branches
                </a>
                <a asp-controller="Accounts" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                    <i class="bi bi-wallet2"></i> Accounts
                </a>
                <a asp-controller="Transactions" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                    <i class="bi bi-arrow-left-right"></i> Transactions
                </a>
            </nav>
            <div class="p-4 mt-auto">
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="bg-slate-800/50 p-4 rounded-xl border border-slate-700">
                        <p class="text-xs text-slate-500 uppercase font-bold tracking-wider mb-2">Admin Console</p>
                        <p class="text-sm text-slate-300 mb-3">System Status: <span class="text-emerald-500">Operational</span></p>
                        <form asp-controller="Auth" asp-action="Logout" method="post">
                            <button type="submit" class="w-full py-2 bg-red-500/10 text-red-400 rounded hover:bg-red-500/20 text-xs font-bold transition-colors">Logout</button>
                        </form>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="block text-center w-full py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">Login</a>
                }
            </div>
        </aside>

        <main class="flex-1 flex flex-col min-w-0">
            <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 shadow-sm shrink-0">
                <div class="flex items-center flex-1">
                    <div class="relative w-96">
                        <input type="text" placeholder="Search customers, accounts, or transactions..." class="w-full pl-10 pr-4 py-2 bg-slate-100 border-none rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:outline-none">
                        <i class="bi bi-search text-slate-400 absolute left-3 top-2.5"></i>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <button class="p-2 text-slate-400 hover:text-slate-600 relative">
                        <i class="bi bi-bell fs-5"></i>
                        <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                    </button>
                    <div class="h-8 w-[1px] bg-slate-200 mx-2"></div>
                    <div class="flex items-center gap-3">
                        <div class="text-right">
                            <p class="text-sm font-semibold">@User.Identity.Name</p>
                            <p class="text-xs text-slate-500">Manager Profile</p>
                        </div>
                        <div class="w-10 h-10 bg-slate-200 rounded-full overflow-hidden border-2 border-slate-100 flex items-center justify-center text-slate-500">
                            <i class="bi bi-person-fill"></i>
                        </div>
                    </div>
                </div>
            </header>

            <div class="p-8 flex-1 overflow-auto space-y-6">
                @RenderBody()
            </div>

            <footer class="h-12 bg-white border-t border-slate-200 px-8 flex items-center justify-between shrink-0">
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                    <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Sync Status: Active (Latency 12ms)</span>
                </div>
                <div class="text-[10px] text-slate-400">
                    © @DateTime.Now.Year Vanguard Systems Management • Version 4.2.1-stable
                </div>
            </footer>
        </main>
    }
    else
    {
        <main class="flex-1 overflow-auto bg-slate-50">
            @RenderBody()
        </main>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>