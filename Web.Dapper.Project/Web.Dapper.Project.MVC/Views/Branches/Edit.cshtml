@model Branch
@{
    ViewData["Title"] = "Edit Branch";
}

<div class="mb-6">
    <a asp-action="Index" class="text-sm font-medium text-slate-500 hover:text-slate-800 flex items-center gap-1 mb-2"><i class="bi bi-arrow-left"></i> Back to List</a>
    <h1 class="text-2xl font-bold text-slate-900">Edit Branch</h1>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 max-w-2xl">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="grid grid-cols-1 gap-6">
            <div>
                <label asp-for="BranchName" class="block text-sm font-semibold text-slate-700 mb-1">Branch Name</label>
                <input asp-for="BranchName" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" />
                <span asp-validation-for="BranchName" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="City" class="block text-sm font-semibold text-slate-700 mb-1">City</label>
                <input asp-for="City" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" />
                <span asp-validation-for="City" class="text-red-500 text-xs mt-1 block"></span>
            </div>
        </div>
        <div class="mt-8 pt-6 border-t border-slate-100">
            <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 shadow-lg shadow-blue-500/20 transition-all">Save Changes</button>
        </div>
    </form>
</div>\n