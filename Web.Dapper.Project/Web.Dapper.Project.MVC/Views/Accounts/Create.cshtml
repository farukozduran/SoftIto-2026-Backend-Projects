@model Account
@{
    ViewData["Title"] = "Open Account";
}

<div class="mb-6">
    <a asp-action="Index" class="text-sm font-medium text-slate-500 hover:text-slate-800 flex items-center gap-1 mb-2"><i class="bi bi-arrow-left"></i> Back to List</a>
    <h1 class="text-2xl font-bold text-slate-900">Open New Account</h1>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 max-w-3xl">
    <form asp-action="Create" method="post">
        <div class="grid grid-cols-2 gap-6">
            <div>
                <label asp-for="CustomerId" class="block text-sm font-semibold text-slate-700 mb-1">Customer</label>
                <select asp-for="CustomerId" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" asp-items="ViewBag.Customers">
                    <option value="">-- Select Customer --</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="BranchId" class="block text-sm font-semibold text-slate-700 mb-1">Branch</label>
                <select asp-for="BranchId" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" asp-items="ViewBag.Branches">
                    <option value="">-- Select Branch --</option>
                </select>
                <span asp-validation-for="BranchId" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="AccountNumber" class="block text-sm font-semibold text-slate-700 mb-1">Account Number</label>
                <div class="flex">
                    <span class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-slate-200 bg-slate-100 text-slate-500 sm:text-sm font-mono">#</span>
                    <input asp-for="AccountNumber" class="flex-1 w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-r-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all font-mono" placeholder="10-digit number" />
                </div>
                <span asp-validation-for="AccountNumber" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Currency" class="block text-sm font-semibold text-slate-700 mb-1">Currency</label>
                    <select asp-for="Currency" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all">
                        <option value="USD">USD ($)</option>
                        <option value="EUR">EUR (€)</option>
                        <option value="TRY">TRY (₺)</option>
                    </select>
                    <span asp-validation-for="Currency" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Balance" class="block text-sm font-semibold text-slate-700 mb-1">Initial Balance</label>
                    <input asp-for="Balance" type="number" step="0.01" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all text-right font-mono" value="0.00" />
                    <span asp-validation-for="Balance" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
            <div class="col-span-2 pt-2">
                <label class="flex items-center cursor-pointer">
                    <div class="relative">
                        <input type="checkbox" asp-for="IsActive" class="sr-only peer" checked>
                        <div class="block bg-slate-200 w-10 h-6 rounded-full transition-colors peer-checked:bg-blue-600"></div>
                        <div class="dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform peer-checked:translate-x-4"></div>
                    </div>
                    <div class="ml-3 text-sm font-medium text-slate-700">Account is Active</div>
                </label>
            </div>
        </div>
        <div class="mt-8 pt-6 border-t border-slate-100">
            <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 shadow-lg shadow-blue-500/20 transition-all">Open Account</button>
        </div>
    </form>
</div>\n