@model Account
@{
    ViewData["Title"] = "Edit Account";
}

<div class="mb-6">
    <a asp-action="Index" class="text-sm font-medium text-slate-500 hover:text-slate-800 flex items-center gap-1 mb-2"><i class="bi bi-arrow-left"></i> Back to List</a>
    <h1 class="text-2xl font-bold text-slate-900">Edit Account</h1>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 max-w-3xl">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="AccountNumber" />
        <div class="grid grid-cols-2 gap-6">
            <div class="col-span-2">
                <div class="p-4 bg-slate-50 rounded-xl border border-slate-200">
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-widest block mb-1">Account Number</span>
                    <div class="text-xl font-mono font-bold text-slate-800">@Model.AccountNumber</div>
                </div>
            </div>
            <div>
                <label asp-for="CustomerId" class="block text-sm font-semibold text-slate-700 mb-1">Customer</label>
                <select asp-for="CustomerId" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" asp-items="ViewBag.Customers"></select>
                <span asp-validation-for="CustomerId" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="BranchId" class="block text-sm font-semibold text-slate-700 mb-1">Branch</label>
                <select asp-for="BranchId" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" asp-items="ViewBag.Branches"></select>
                <span asp-validation-for="BranchId" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Currency" class="block text-sm font-semibold text-slate-700 mb-1">Currency</label>
                <select asp-for="Currency" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all">
                    <option value="USD">USD ($)</option>
                    <option value="EUR">EUR (€)</option>
                    <option value="TRY">TRY (₺)</option>
                </select>
                <span asp-validation-for="Currency" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Balance" class="block text-sm font-semibold text-slate-700 mb-1">Balance</label>
                <input asp-for="Balance" type="number" step="0.01" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all text-right font-mono" />
                <span asp-validation-for="Balance" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div class="col-span-2 pt-2">
                <label class="flex items-center cursor-pointer">
                    <div class="relative">
                        <input type="checkbox" asp-for="IsActive" class="sr-only peer">
                        <div class="block bg-slate-200 w-10 h-6 rounded-full transition-colors peer-checked:bg-blue-600"></div>
                        <div class="dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform peer-checked:translate-x-4"></div>
                    </div>
                    <div class="ml-3 text-sm font-medium text-slate-700">Account is Active</div>
                </label>
            </div>
        </div>
        <div class="mt-8 pt-6 border-t border-slate-100">
            <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 shadow-lg shadow-blue-500/20 transition-all">Save Changes</button>
        </div>
    </form>
</div>\n