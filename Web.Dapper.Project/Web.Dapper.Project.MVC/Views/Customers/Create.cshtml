@model Customer
@{
    ViewData["Title"] = "Add Customer";
}

<div class="mb-6">
    <a asp-action="Index" class="text-sm font-medium text-slate-500 hover:text-slate-800 flex items-center gap-1 mb-2"><i class="bi bi-arrow-left"></i> Back to List</a>
    <h1 class="text-2xl font-bold text-slate-900">Add New Customer</h1>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 max-w-3xl">
    <form asp-action="Create" method="post">
        <div class="grid grid-cols-2 gap-6">
            <div>
                <label asp-for="FirstName" class="block text-sm font-semibold text-slate-700 mb-1">First Name</label>
                <input asp-for="FirstName" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" />
                <span asp-validation-for="FirstName" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="LastName" class="block text-sm font-semibold text-slate-700 mb-1">Last Name</label>
                <input asp-for="LastName" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" />
                <span asp-validation-for="LastName" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="IdentityNumber" class="block text-sm font-semibold text-slate-700 mb-1">Identity Number</label>
                <input asp-for="IdentityNumber" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" maxlength="11" />
                <span asp-validation-for="IdentityNumber" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Email" class="block text-sm font-semibold text-slate-700 mb-1">Email Address</label>
                <input asp-for="Email" type="email" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all" />
                <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div class="col-span-2">
                <label asp-for="PasswordHash" class="block text-sm font-semibold text-slate-700 mb-1">Initial Password</label>
                <input asp-for="PasswordHash" type="password" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all max-w-md" />
                <span asp-validation-for="PasswordHash" class="text-red-500 text-xs mt-1 block"></span>
            </div>
        </div>
        <div class="mt-8 pt-6 border-t border-slate-100">
            <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 shadow-lg shadow-blue-500/20 transition-all">Create Customer</button>
        </div>
    </form>
</div>\n