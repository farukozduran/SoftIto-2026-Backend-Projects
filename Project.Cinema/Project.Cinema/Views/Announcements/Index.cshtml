@{
    ViewData["Title"] = "Duyuru Yönetimi";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-white">Duyuru Yönetimi</h2>
            <p class="text-muted mb-0">Duyurular AJAX ile listeleniyor.</p>
        </div>

        <button type="button"
                class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#announcementModal"
                onclick="openAddAnnouncementModal()">
            + Yeni Duyuru Ekle
        </button>
    </div>

    <div class="glass-card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle custom-table">
                    <thead>
                        <tr>
                            <th>Durum</th>
                            <th>Başlık</th>
                            <th>İçerik</th>
                            <th>Yayın Tarihi</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody id="announcementTableBody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Duyuru Ekleme Modal -->
<div class="modal fade custom-modal" id="announcementModal" tabindex="-1" aria-labelledby="announcementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header">
                <h5 class="modal-title" id="announcementModalLabel">Yeni Duyuru Ekle</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="announcementId" />
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label">Başlık</label>
                        <input type="text" id="title" class="form-control" placeholder="Duyuru Başlığı">
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">İçerik</label>
                        <textarea id="content" class="form-control" rows="4" placeholder="Duyuru Detayı..."></textarea>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Yayın Tarihi</label>
                        <input type="date" id="publishDate" class="form-control">
                    </div>

                    <div class="col-md-6 d-flex align-items-center mt-5">
                        <div class="form-check form-switch fs-5">
                            <input class="form-check-input" type="checkbox" role="switch" id="isActive" checked>
                            <label class="form-check-label text-white ms-2" for="isActive">Aktif (Yayında)</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">
                    Kapat
                </button>
                <button type="button" class="btn btn-primary" id="btnAddAnnouncement" onclick="addAnnouncement()">
                    Kaydet
                </button>

                <button type="button" class="btn btn-warning" id="btnUpdateAnnouncement" onclick="updateAnnouncement()" style="display:none;">
                    Güncelle
                </button>
            </div>
        </div>
    </div>
</div>
