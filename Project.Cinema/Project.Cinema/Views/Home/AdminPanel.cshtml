@{
    ViewData["Title"] = "Admin Panel";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold text-white">Yönetim Paneli</h1>
        <p class="text-muted">Film, seans ve duyuru işlemlerini buradan yönetebilirsiniz.</p>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-4">
            <div class="glass-card h-100 text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-film fs-1 text-primary"></i>
                </div>
                <h4 class="fw-bold text-white">Film Yönetimi</h4>
                <p class="text-muted mb-4">Filmleri listele, ekle, düzenle ve sil.</p>
                <a asp-controller="Movies" asp-action="Index" class="btn btn-primary w-100">
                    Filmlere Git
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="glass-card h-100 text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-camera-reels fs-1 text-primary"></i>
                </div>
                <h4 class="fw-bold text-white">Seans Yönetimi</h4>
                <p class="text-muted mb-4">Film seanslarını yönet.</p>
                <a asp-controller="Sessions" asp-action="Index" class="btn btn-primary w-100">
                    Seanslara Git
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="glass-card h-100 text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-megaphone fs-1 text-primary"></i>
                </div>
                <h4 class="fw-bold text-white">Duyuru Yönetimi</h4>
                <p class="text-muted mb-4">Sinema duyurularını yönet.</p>
                <a asp-controller="Announcements" asp-action="Index" class="btn btn-primary w-100">
                    Duyurulara Git
                </a>
            </div>
        </div>
    </div>
</div>