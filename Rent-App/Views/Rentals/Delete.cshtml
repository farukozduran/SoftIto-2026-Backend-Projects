@model Rent.App.Models.Rental

@{
    ViewData["Title"] = "Kiralama Sil";
}

<div class="container py-5">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-danger text-white rounded-top-4">
            <h3 class="mb-0">Kiralama Silme Onayı</h3>
        </div>

        <div class="card-body p-4">
            <p class="fs-5">Bu kiralama kaydını silmek istediğine emin misin?</p>

            <dl class="row">
                <dt class="col-sm-3">Müşteri</dt>
                <dd class="col-sm-9">@Model.Customer.CustomerName @Model.Customer.CustomerSurname</dd>

                <dt class="col-sm-3">Araç</dt>
                <dd class="col-sm-9">@Model.Car.Brand @Model.Car.Model - @Model.Car.Plate</dd>

                <dt class="col-sm-3">Tarih</dt>
                <dd class="col-sm-9">@Model.RentDate - @Model.ReturnDate</dd>

                <dt class="col-sm-3">Toplam Ücret</dt>
                <dd class="col-sm-9">@Model.TotalPrice ₺</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="RentalId" />

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    <button type="submit" class="btn btn-danger">Evet, Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>