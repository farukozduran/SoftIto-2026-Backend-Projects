<!--home page-->
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <!-- Bootstrap -->
        <link
            href="~/css/bootstrap.min.css"
            rel="stylesheet">

        <!-- Bootstrap Icons -->
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
            rel="stylesheet">

        <!-- Custom CSS -->
        <link rel="stylesheet" href="~/css/style.css">
        <link rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap"
            rel="stylesheet" />
        <!--Aos -->
        <link rel="stylesheet"
            href="https://unpkg.com/aos@2.3.1/dist/aos.css" />

        <link rel="shortcut icon" href="~/img/download (35).png"
            type="image/x-icon">
        <title>Rent a Car</title>
    </head>
    <body>
        <!--header section -->
        <header>
            <!-- Navbar -->
            <nav class="navbar main-nav fixed-top py-3 navbar-expand-lg">
                <div
                    class="container d-flex justify-content-between align-items-center">

                    <!-- Logo -->
                    <div class="d-flex align-items-center gap-2 brand-logo">
                        <i class="fa-solid fa-car-side"></i>
                        <h4 class="fw-bold m-0 Logo">Rent a Car</h4>
                    </div>

                    <!-- Desktop Menu (visible on large screens only) -->
                    <ul class="nav d-none d-lg-flex">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cars" asp-action="Index">Cars</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Customers" asp-action="Index">Customers</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Rentals" asp-action="Index">Rentals</a>
                        </li>
                    </ul>

                    <a asp-controller="Admin" asp-action="Index"
                       class="btn px-4 d-none d-lg-block">
                        Admin
                    </a>

                    <!-- Burger Button (Mobile Only) -->
                    <button class="navbar-toggler d-lg-none"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#mobileMenu">

                        <i class="bi bi-list fs-1"></i>
                    </button>

                </div>
            </nav>

            <!-- Offcanvas Mobile Menu -->
            <div class="offcanvas offcanvas-end" id="mobileMenu"
                style="background-color: #8a7aff;">

                <div class="offcanvas-header">
                    <div class="d-flex align-items-center gap-2 brand-logo">
                        <i class="fa-solid fa-tooth"></i>
                        <h4 class="fw-bold m-0">Rent a Car</h4>
                    </div>

                    <button class="btn-close"
                        data-bs-dismiss="offcanvas"></button>
                </div>

                <div class="offcanvas-body">

                    <ul class="navbar-nav gap-2">
                        <li>
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li>
                            <a class="nav-link" asp-controller="Cars" asp-action="Index">Cars</a>
                        </li>

                        <li>
                            <a class="nav-link" asp-controller="Customers" asp-action="Index">Customers</a>
                        </li>

                        <li>
                            <a class="nav-link" asp-controller="Rentals" asp-action="Index">Rentals</a>
                        </li>
                    </ul>

                    <a asp-controller="Rentals" asp-action="Create" class="btn w-100 mt-3">
                        Rent Now
                    </a>

                </div>

            </div>
        </header>
        <!-- Hero Section -->
        <section class="hero-modern">
            <div class="container">
                <div class="row align-items-center">

                    <!-- LEFT TEXT -->
                    <div class="col-md-6">

                        <h1 class="hero-title">
                            Fast, Reliable & Comfortable Car Rental
                        </h1>

                        <p class="hero-desc">
                            Choose the right car for your journey. 
                            Manage vehicles, customers and rental records 
                            easily from one modern system.
                        </p>

                        <div class="d-flex gap-3 mt-3">
                            <a asp-controller="Cars" asp-action="Index" class="btn hero-btn px-4">
                                View Cars
                            </a>

                            <a asp-controller="Rentals" asp-action="Create" class="btn btn-outline-dark px-4">
                                Rent Now
                            </a>
                        </div>

                        <!-- Rating Box -->
                        <div class="hero-rating mt-4">
                            <span class="rating-value">4.8★</span>
                            <span class="rating-text">Customer Satisfaction Rating</span>
                        </div>

                    </div>

                    <!-- RIGHT IMAGE -->
                    <div class="col-md-6 position-relative">
                        <img src="https://img.magnific.com/free-vector/transport-flat-muscle-car-illustration_23-2149450022.jpg?semt=ais_hybrid&w=740&q=80"
                            class="hero-img" />
                    </div>

                </div>
            </div>
        </section>
        @RenderBody()
        <!-- blog section-->
        <section class="container my-5" data-aos="fade-up">

            <div class="text-center mb-4">
                <span class="blog-tag">Rental Tips</span>
                <h2 class="fw-bold">Latest Car Rental Articles</h2>
                <p class="text-muted">
                    Useful tips about car rental, vehicle selection and safe driving.
                </p>
            </div>

            <div class="row g-4">

                <!-- Blog Item -->
                <div class="col-md-6">
                    <div class="blog-card d-flex">

                        <img src="https://img.magnific.com/premium-vector/traveling-car-illustration_126895-243.jpg"
                            class="blog-img">

                        <div class="blog-content">
                            <h5 class="fw-bold">How to Choose the Right Car for Your Trip</h5>
                            <p>Choose the best vehicle depending on distance, 
                                luggage and comfort needs.
                            </p>
                            <small class="text-muted">March 28, 2024</small>
                            <a href="#" class="read-link">Read More →</a>
                        </div>

                    </div>
                </div>

                <!-- Blog Item -->
                <div class="col-md-6">
                    <div class="blog-card d-flex">

                        <img
                            src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSqlTdcXnMOHO53F7AVdtTE5MpMFZozm3kdom7qJQBi1cxM1ttNBAHH7f1T&s=10"
                            class="blog-img">

                        <div class="blog-content">
                            <h5 class="fw-bold">Daily or Weekly Rental: Which One is Better?</h5>
                            <p>Compare rental periods and find the most cost-effective option.</p>
                            <small class="text-muted">March 28, 2024</small>
                            <a href="#" class="read-link">Read More →</a>
                        </div>
                    </div>
                </div>

                <!-- Blog Item -->
                <div class="col-md-6">
                    <div class="blog-card d-flex">

                        <img src="https://img.magnific.com/premium-vector/car-rental-concept-illustration_114360-9267.jpg"
                            class="blog-img">

                        <div class="blog-content">
                            <h5 class="fw-bold">Important Things Before Renting a Car</h5>
                            <p>Check plate, fuel status, insurance and delivery conditions before renting.</p>
                            <small class="text-muted">March 28, 2024</small>
                            <a href="#" class="read-link">Read More →</a>
                        </div>

                    </div>
                </div>

                <!-- Blog Item -->
                <div class="col-md-6">
                    <div class="blog-card d-flex">

                        <img src="https://media.istockphoto.com/id/2184963463/vector/auto-insurance-character-buying-or-renting-car-and-signing-full-coverage-insurance-policy.jpg?s=612x612&w=0&k=20&c=p4ZM6MyFeWjeTALgF-iL9txmelDZQ-gY5dmxQE9iHtc="
                            class="blog-img">

                        <div class="blog-content">
                            <h5 class="fw-bold">Why Customer Records Matter in Rental Systems</h5>
                            <p>Organized customer data helps manage rentals faster and safer.</p>
                            <small class="text-muted">March 27, 2024</small>
                            <a href="#" class="read-link">Read More →</a>
                        </div>

                    </div>
                </div>

            </div>

        </section>
        <!-- Stats Section -->
        <section class="stats-section py-5">

            <div class="container stats-box">
                <div class="row text-center">

                    <!-- Happy Patients -->
                    <div class="col-md-3">
                        <i class="bi bi-people stats-icon"></i>
                        <h3 class="counter" data-target="1452">0</h3>
                        <p class="stats-label">Happy Customers</p>
                    </div>

                    <!-- Online Appointments -->
                    <div class="col-md-3">
                        <i class="bi bi-file-earmark-text stats-icon"></i>
                        <h3 class="counter" data-target="342">0</h3>
                        <p class="stats-label">Completed Rentals</p>
                    </div>

                    <!-- Years of Experience -->
                    <div class="col-md-3">
                        <i class="bi bi-award stats-icon"></i>
                        <h3 class="counter" data-target="15">0</h3>
                        <p class="stats-label">Years of Experience</p>
                    </div>

                    <!-- Doctors & Staff -->
                    <div class="col-md-3">
                        <i class="bi bi-person-badge stats-icon"></i>
                        <h3 class="counter" data-target="20">0</h3>
                        <p class="stats-label">Available Cars</p>
                    </div>

                </div>
            </div>

        </section>
        <!-- Footer Section -->
        <footer class="footer-section py-5 mt-5">

            <div class="container">
                <!-- Bottom Bar -->
                <div
                    class="d-flex justify-content-between align-items-center flex-wrap">

                    <div class="d-flex align-items-center gap-2 logo">
                        <i class="fa-solid fa-car-side"></i>
                        <strong> Rent a Car</strong>
                    </div>

                    <small class="text-muted">
                        Copyright © Rent a Car — Designed by Faruk —
                        <br>
                        <p class="text-center"> Developed by <a target="_blank" href="https://github.com/farukozduran">Faruk Özduran</p>
                    </small>

                    <div class="social-icons d-flex gap-2">
                        <i class="bi bi-facebook"></i>
                        <i class="bi bi-twitter"></i>
                        <i class="bi bi-instagram"></i>
                        <i class="bi bi-youtube"></i>
                        <i class="bi bi-linkedin"></i>
                    </div>

                </div>

            </div>

        </footer>

        <!-- Bootstrap JS && custom js-->
        <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
        <script
            src="~/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/main.js"></script>
    </body>
</html>