@model IEnumerable<Rent.App.Models.Customer>

@{
    ViewData["Title"] = "Müşteriler";
    bool isAdmin = ViewData["IsAdmin"] != null && (bool)ViewData["IsAdmin"];
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Müşteri Listesi</h2>
        @if (!isAdmin)
        {
            <a asp-action="Create" class="btn btn-primary">Yeni Müşteri</a>
        }
    </div>
    <form asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text"
                   name="search"
                   value="@ViewData["CurrentSearch"]"
                   class="form-control"
                   placeholder="Search by customer name, phone or email..." />

            <button type="submit" class="btn btn-primary">
                Search
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Clear
            </a>
        </div>
    </form>

    <div class="table-responsive shadow rounded-4">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Ad Soyad</th>
                    <th>Telefon</th>
                    <th>Email</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.CustomerName @item.CustomerSurname</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td class="text-end">
                            @if (isAdmin)
                            {
                                <a asp-action="Edit" asp-route-id="@item.CustomerId" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.CustomerId" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>