@using Rent.App.Models

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var lastThreeRentals = ViewBag.LastThreeRentals as List<Rental>;
    var firstThreeCustomers = ViewBag.FirstThreeCustomers as List<Customer>;
    var lastThreeCustomers = ViewBag.LastThreeCustomers as List<Customer>;
    var carsContainsA = ViewBag.CarsContainsA as List<Car>;
    var customersContainsA = ViewBag.CustomersContainsA as List<Customer>;
}

<h1 class="h3 mb-4 text-gray-800">Admin Dashboard</h1>

<div class="row">

    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">

                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Customer Management
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            Edit or delete customers
                        </div>
                    </div>

                    <div class="col-auto">
                        <i class="fas fa-users fa-2x text-gray-300"></i>
                    </div>

                </div>

                <div class="mt-3">
                    <a asp-controller="Customers" asp-action="Index" class="btn btn-primary btn-sm">
                        Manage Customers
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">

                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Car Management
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            Edit or delete cars
                        </div>
                    </div>

                    <div class="col-auto">
                        <i class="fas fa-car fa-2x text-gray-300"></i>
                    </div>

                </div>

                <div class="mt-3">
                    <a asp-controller="Cars" asp-action="Index" class="btn btn-success btn-sm">
                        Manage Cars
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">

                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Rental Management
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            Edit or delete rentals
                        </div>
                    </div>

                    <div class="col-auto">
                        <i class="fas fa-key fa-2x text-gray-300"></i>
                    </div>

                </div>

                <div class="mt-3">
                    <a asp-controller="Rentals" asp-action="Index" class="btn btn-warning btn-sm">
                        Manage Rentals
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>

<hr />

<h2 class="h4 mb-4 text-gray-800">Reports</h2>

<div class="row">

    <!-- Last 3 Rentals -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 bg-primary">
                <h6 class="m-0 font-weight-bold text-white">Last 3 Rentals</h6>
            </div>

            <div class="card-body">
                @if (lastThreeRentals != null && lastThreeRentals.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Customer</th>
                                    <th>Car</th>
                                    <th>Rent Date</th>
                                    <th>Total Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in lastThreeRentals)
                                {
                                    <tr>
                                        <td>@item.Customer.CustomerName @item.Customer.CustomerSurname</td>
                                        <td>@item.Car.Brand @item.Car.Model</td>
                                        <td>@item.RentDate</td>
                                        <td>@item.TotalPrice ₺</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No rental records found.</p>
                }
            </div>
        </div>
    </div>

    <!-- First 3 Customers -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 bg-success">
                <h6 class="m-0 font-weight-bold text-white">First 3 Customers</h6>
            </div>

            <div class="card-body">
                @if (firstThreeCustomers != null && firstThreeCustomers.Any())
                {
                    <ul class="list-group">
                        @foreach (var item in firstThreeCustomers)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @item.CustomerName @item.CustomerSurname
                                <span class="badge badge-success">@item.Email</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">No customer records found.</p>
                }
            </div>
        </div>
    </div>

    <!-- Last 3 Customers -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 bg-warning">
                <h6 class="m-0 font-weight-bold text-white">Last 3 Customers</h6>
            </div>

            <div class="card-body">
                @if (lastThreeCustomers != null && lastThreeCustomers.Any())
                {
                    <ul class="list-group">
                        @foreach (var item in lastThreeCustomers)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @item.CustomerName @item.CustomerSurname
                                <span class="badge badge-warning">@item.Phone</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">No customer records found.</p>
                }
            </div>
        </div>
    </div>

    <!-- Cars Containing A -->
    <div class="col-lg-6 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 bg-danger">
                <h6 class="m-0 font-weight-bold text-white">Cars Containing Letter "A"</h6>
            </div>

            <div class="card-body">
                @if (carsContainsA != null && carsContainsA.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Brand</th>
                                    <th>Model</th>
                                    <th>Plate</th>
                                    <th>Daily Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in carsContainsA)
                                {
                                    <tr>
                                        <td>@item.Brand</td>
                                        <td>@item.Model</td>
                                        <td>@item.Plate</td>
                                        <td>@item.DailyPrice ₺</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No cars found.</p>
                }
            </div>
        </div>
    </div>

    <!-- Customers Containing A -->
    <div class="col-lg-12 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 bg-dark">
                <h6 class="m-0 font-weight-bold text-white">Customers Containing Letter "A"</h6>
            </div>

            <div class="card-body">
                @if (customersContainsA != null && customersContainsA.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Customer Name</th>
                                    <th>Customer Surname</th>
                                    <th>Phone</th>
                                    <th>Email</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in customersContainsA)
                                {
                                    <tr>
                                        <td>@item.CustomerName</td>
                                        <td>@item.CustomerSurname</td>
                                        <td>@item.Phone</td>
                                        <td>@item.Email</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No customers found.</p>
                }
            </div>
        </div>
    </div>

</div>