@model IEnumerable<Rent.App.Models.Car>

@{
    ViewData["Title"] = "Araçlar";
    bool isAdmin = ViewData["IsAdmin"] != null && (bool)ViewData["IsAdmin"];
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Araç Listesi</h2>
        @if (!isAdmin)
        {
            <a asp-action="Create" class="btn btn-dark">Yeni Araç Ekle</a>
        }
    </div>
    <form asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text"
                   name="search"
                   value="@ViewData["CurrentSearch"]"
                   class="form-control"
                   placeholder="Search by brand, model or plate..." />

            <button type="submit" class="btn btn-dark">
                Search
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Clear
            </a>
        </div>
    </form>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 rounded-4">
                    <div class="card-body">
                        <h4 class="fw-bold">@item.Brand @item.Model</h4>
                        <p class="text-muted mb-2">Plaka: @item.Plate</p>
                        <h5 class="text-success">@item.DailyPrice ₺ / Gün</h5>
                    </div>

                    <div class="card-footer bg-white border-0 d-flex gap-2">
                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@item.CarId" class="btn btn-outline-warning w-50">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.CarId" class="btn btn-outline-danger w-50">Delete</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>