@model Rent.App.Models.Car

@{
    ViewData["Title"] = "Yeni Araç Ekle";
}

<div class="container py-5">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-dark text-white rounded-top-4">
            <h3 class="mb-0">Yeni Araç Ekle</h3>
        </div>

        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Brand" class="form-label">Marka</label>
                        <input asp-for="Brand" class="form-control" placeholder="BMW, Mercedes, Toyota..." />
                        <span asp-validation-for="Brand" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Model" class="form-label">Model</label>
                        <input asp-for="Model" class="form-control" placeholder="320i, Corolla, Clio..." />
                        <span asp-validation-for="Model" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Plate" class="form-label">Plaka</label>
                        <input asp-for="Plate" class="form-control" placeholder="34 ABC 123" />
                        <span asp-validation-for="Plate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DailyPrice" class="form-label">Günlük Ücret</label>
                        <input asp-for="DailyPrice" class="form-control" placeholder="1500" />
                        <span asp-validation-for="DailyPrice" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Listeye Dön</a>
                    <button type="submit" class="btn btn-dark px-4">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>