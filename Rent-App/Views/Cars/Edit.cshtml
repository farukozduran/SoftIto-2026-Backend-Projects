@model Rent.App.Models.Car

@{
    ViewData["Title"] = "Araç Düzenle";
}

<div class="container py-5">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-warning text-dark rounded-top-4">
            <h3 class="mb-0">Araç Bilgilerini Düzenle</h3>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit">
                <input type="hidden" asp-for="CarId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Brand" class="form-label">Marka</label>
                        <input asp-for="Brand" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Model" class="form-label">Model</label>
                        <input asp-for="Model" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Plate" class="form-label">Plaka</label>
                        <input asp-for="Plate" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DailyPrice" class="form-label">Günlük Ücret</label>
                        <input asp-for="DailyPrice" class="form-control" />
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
                    <button type="submit" class="btn btn-warning px-4">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>